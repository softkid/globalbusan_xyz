# Monorepo gitignore

# Node modules
node_modules/
frontend/node_modules/
backend/node_modules/
frontend-admin/node_modules/

# Build outputs
dist/
build/
frontend/dist/
frontend/build/
backend/dist/
backend/build/
frontend-admin/dist/
frontend-admin/build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
backend/.env
backend/.env.local
frontend-admin/.env
frontend-admin/.env.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Testing
coverage/
.nyc_output
frontend/coverage/
backend/coverage/
frontend-admin/coverage/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Temporary files
*.tmp
.cache/
.temp/
.vercel
.turbo

# Production
.vercel
.netlify

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.bash.exe.stackdump
bash.exe.stackdump
*.stackdump
